{
  "expo": {
    "name": "BioNum",
    "slug": "bionum-client",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/ios-icon.png",
    "scheme": "bionumclient",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yahyagazizuly.bionumclient",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.yahyagazizuly.bionumclient",
      "adaptiveIcon": {
        "foregroundImage": "./assets/ios-icon.png",
        "backgroundColor": "#E6F4FE"
      }
    },
    "plugins": [
      "expo-router",
      "expo-notifications"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3773f10a-1822-44bf-89ff-ff384b969394"
      }
    }
  }
}
